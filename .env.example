# Copy to .env for local development. Never commit a filled-in .env.

APP_ENV=development

# Telegram
BOT_TOKEN=
BOT_USERNAME=ZooParkBot

# Lets X-Dev-User-Id impersonate a player without a Telegram signature.
# Only ever 1 in development; the app refuses to start with this on in production.
DEV_AUTH=1

# CSV whitelist of Telegram ids allowed into the game. "*" opens it to everyone.
ALLOWED_TG_IDS=474701274

# CSV whitelist for the owner-only admin panel. Keep this separate from ALLOWED_TG_IDS.
ADMIN_TG_IDS=474701274

# Reject initData older than this, so a captured payload cannot be replayed forever.
INIT_DATA_MAX_AGE_SECONDS=86400

# Must match the secret_token passed to Telegram's setWebhook.
# Generate with: openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=

# MySQL
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=admin_zoopark
DB_PASSWORD=
DB_NAME=zoopark

# AI rivals (webzooparkbot-bots service). Read only by the bot runner — the API never
# calls the model. Without a key the rivals keep playing on their fallback plans, so a
# missing value degrades them rather than breaking the game.
ROUTERAI_API_KEY=
ROUTERAI_BASE_URL=https://routerai.ru/api/v1
BOT_PLANNER_MODEL=deepseek/deepseek-v4-flash
# Where each rival keeps the notes it writes itself through the `remember` tool.
BOT_MEMORY_DIR=/opt/webzooparkbot/bot_memory

# Frontend (build time)
VITE_API_URL=/api

# Comma-separated browser origins allowed to call the API. Same-origin production
# deployments can leave this empty; local Vite development uses localhost by default.
CORS_ORIGINS=http://localhost:5173
